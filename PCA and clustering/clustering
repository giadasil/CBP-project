import MDAnalysis as mda
from MDAnalysis.analysis import align
from sklearn.cluster import KMeans
import matplotlib.pyplot as plt
import numpy as np
import pandas as pd

def run_clustering_analysis(pdb_file, xtc_file, system_name, n_clusters=3, step=10):
    print(f"\n--- Starting Analysis for {system_name} ---")
    
    u = mda.Universe(pdb_file, xtc_file)
    
    # Structural alignment
    # Align all frames to the first frame CA atoms to remove global drift
    print(f"Aligning {system_name} trajectory...")
    u.trajectory[0]
    align.AlignTraj(u, u, select='name CA', in_memory=True).run()
    
    # Extract CA coordinates for clustering
    ca = u.select_atoms("name CA")
    coords = []
    for ts in u.trajectory[::step]:
        coords.append(ca.positions.flatten())
    coords = np.array(coords)
    
    # Perform k-means clustering
    print(f"Clustering {system_name} into {n_clusters} states...")
    km = KMeans(n_clusters=n_clusters, random_state=42, n_init=10)
    labels = km.fit_predict(coords)
    
    # Population analysis
    total_points = len(labels)
    unique, counts = np.unique(labels, return_counts=True)
    percentages = (counts / total_points) * 100
    
    # Find and save representative centroids
    for i in range(n_clusters):
        cluster_indices = np.where(labels == i)[0]
        if len(cluster_indices) == 0: continue
        
        center = km.cluster_centers_[i]
        # Find frame in the subset closest to the mathematical center
        distances = np.linalg.norm(coords[cluster_indices] - center, axis=1)
        best_sub_index = np.argmin(distances)
        
        # Map back to original trajectory frame
        original_frame = cluster_indices[best_sub_index] * step
        
        u.trajectory[original_frame]
        output_name = f"{system_name.replace(' ', '_')}_cluster_{i}.pdb"
        u.atoms.write(output_name)
        print(f"  > Cluster {i} ({percentages[i]:.1f}%) saved as {output_name}")

    return labels, percentages

# Execution
systems = [
    ("wt_protein_only.gro", "wt_protein_only.xtc", "Wild Type"),
    ("af_protein_only.gro", "Alpha_protein_only.xtc", "AlphaFold Mutant"),
    ("chimera_protein_only.gro", "chimera_protein_only.xtc", "Chimera Mutant")
]

all_percentages = []

for pdb, xtc, name in systems:
    _, percs = run_clustering_analysis(pdb, xtc, name)
    all_percentages.append(percs)

labels = [f"Cluster {i}" for i in range(2)]
wt_p = all_percentages[0]
af_p = all_percentages[1]
ch_p = all_percentages[2]

x = np.arange(len(labels))
width = 0.25

fig, ax = plt.subplots(figsize=(10, 6))
ax.bar(x - width, wt_p, width, label='Wild Type', color='blue', alpha=0.7)
ax.bar(x, af_p, width, label='AlphaFold', color='green', alpha=0.7)
ax.bar(x + width, ch_p, width, label='Chimera', color='red', alpha=0.7)

ax.set_ylabel('Population Percentage (%)')
ax.set_title('Conformational State Distribution: WT vs Mutants')
ax.set_xticks(x)
ax.set_xticklabels(labels)
ax.legend()
plt.grid(axis='y', linestyle='--', alpha=0.6)
plt.show()
