import MDAnalysis as mda
from MDAnalysis.analysis import align
from sklearn.cluster import KMeans
import matplotlib.pyplot as plt
import numpy as np
import os

def run_final_clustering(systems, n_clusters=3):
    # Setup global reference for alignment (using first system's first frame)
    ref_gro, _, _ = systems[0]
    ref_u = mda.Universe(ref_gro)
    
    all_percentages = []
    system_names = []

    for gro, xtc, name in systems:
        if not os.path.exists(gro) or not os.path.exists(xtc):
            continue
            
        print(f"\n--- Clustering: {name} ---")
        u = mda.Universe(gro, xtc)
        
        # Determine last 9000 frames
        start_frame = max(0, len(u.trajectory) - 9000)
        
        # 2. Production phase alignment to global reference
        # This ensures Cluster 0 in WT is structurally comparable to clusters in Mutants
        align.AlignTraj(u, ref_u, select='name CA', start=start_frame, in_memory=True).run()
        
        # 3. Coordinate extraction
        ca = u.select_atoms("name CA")
        coords = [ca.positions.flatten() for ts in u.trajectory[start_frame:]]
        coords = np.array(coords)
        
        # 4. K-Means
        km = KMeans(n_clusters=n_clusters, random_state=42, n_init=10)
        labels = km.fit_predict(coords)
        
        # 5. Robust population calculation
        unique, counts = np.unique(labels, return_counts=True)
        raw_percs = (counts / len(labels)) * 100
        
        # Initialize full-length array with zeros
        final_percs = np.zeros(n_clusters)
        for cluster_id, p in zip(unique, raw_percs):
            final_percs[cluster_id] = p
            
        all_percentages.append(final_percs)
        system_names.append(name)
        
        # 6. Save Representative PDBs
        for i in range(n_clusters):
            idx = np.where(labels == i)[0]
            if len(idx) == 0: continue
            
            center = km.cluster_centers_[i]
            # Find frame in the subset closest to the mathematical center
            dist = np.linalg.norm(coords[idx] - center, axis=1)
            best_frame = start_frame + idx[np.argmin(dist)]
            
            u.trajectory[best_frame]
            u.atoms.write(f"{name.replace(' ', '_')}_C{i}.pdb")

    return system_names, all_percentages

systems = [
    ("wt_protein_only.gro", "wt_protein_only.xtc", "Wild Type"),
    ("af_protein_only.gro", "Alpha_protein_only.xtc", "AlphaFold Mutant"),
    ("chimera_protein_only.gro", "chimera_protein_only.xtc", "Chimera Mutant")
]

names, populations = run_final_clustering(systems, n_clusters=3)

# Visualization
x = np.arange(3) # k=3
width = 0.25
colors = ['#3498db', '#2ecc71', '#e74c3c']

fig, ax = plt.subplots(figsize=(10, 6))
for i, (name, p) in enumerate(zip(names, populations)):
    ax.bar(x + (i - 1) * width, p, width, label=name, color=colors[i], edgecolor='black')

ax.set_ylabel('Population (%)')
ax.set_xticks(x)
ax.set_xticklabels([f'Cluster {i}' for i in range(3)])
ax.legend()
plt.title('Final Cluster Populations (Last 9000 Frames, k=3)')
plt.show()
